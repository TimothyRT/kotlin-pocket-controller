<?xml version="1.0" encoding="utf-8"?>
<!--
  res/drawable/bg_btn_secondary.xml
  Dark surface button used for "HOLD: GESTURE" — subtle but still P5-styled.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed / active state (held down) -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="4dp" android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/p5_red_dim" />
                </shape>
            </item>
            <item android:right="4dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/p5_red" />
                    <stroke android:width="1dp" android:color="@color/p5_red_bright" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Disabled state -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/p5_dark_surface" />
            <stroke android:width="1dp" android:color="#1AFF1A1A" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/p5_dark_surface" />
            <stroke android:width="1dp" android:color="#33CC0000" />
        </shape>
    </item>

</selector>
