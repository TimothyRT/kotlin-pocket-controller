<?xml version="1.0" encoding="utf-8"?>
<!--
  res/drawable/bg_btn_outline.xml
  Red-bordered outline button (Connect / Disconnect).
  State-aware: pressed state fills with a dim red.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/p5_red_dim" />
            <stroke android:width="2dp" android:color="@color/p5_red" />
        </shape>
    </item>

    <!-- Disabled state -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/p5_dark_surface" />
            <stroke android:width="2dp" android:color="#33CC0000" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="2dp" android:color="@color/p5_red" />
        </shape>
    </item>

</selector>
