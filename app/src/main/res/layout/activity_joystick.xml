<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/joystick_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:keepScreenOn="true">

    <!-- Status bar -->
    <TextView
        android:id="@+id/text_joy_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● Connecting…"
        android:textColor="@android:color/holo_orange_dark"
        android:textSize="13sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btn_joy_disconnect"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="✕ EXIT"
        android:textSize="11sp"
        android:backgroundTint="#C62828"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="4dp" />

    <!-- System buttons: BACK, START -->
    <Button
        android:id="@+id/btn_back"
        android:layout_width="64dp"
        android:layout_height="32dp"
        android:text="☰ BACK"
        android:textSize="10sp"
        android:backgroundTint="#37474F"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btn_start"
        android:layout_width="64dp"
        android:layout_height="32dp"
        android:text="START ≡"
        android:textSize="10sp"
        android:backgroundTint="#37474F"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="60dp"
        android:layout_marginTop="4dp" />

    <!-- LEFT SIDE -->

    <!-- LT -->
    <Button
        android:id="@+id/btn_lt"
        android:layout_width="80dp"
        android:layout_height="44dp"
        android:text="LT"
        android:textStyle="bold"
        android:backgroundTint="#546E7A"
        app:layout_constraintTop_toBottomOf="@id/text_joy_status"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp" />

    <!-- LB -->
    <Button
        android:id="@+id/btn_lb"
        android:layout_width="80dp"
        android:layout_height="36dp"
        android:text="LB"
        android:textStyle="bold"
        android:backgroundTint="#455A64"
        app:layout_constraintTop_toBottomOf="@id/btn_lt"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp" />

    <!-- Left thumbstick -->
    <com.timothy.joystick.VirtualThumbstick
        android:id="@+id/left_stick"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="12dp" />

    <!-- L3 -->
    <Button
        android:id="@+id/btn_l3"
        android:layout_width="48dp"
        android:layout_height="28dp"
        android:text="L3"
        android:textSize="10sp"
        android:backgroundTint="#263238"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="70dp"
        android:layout_marginBottom="4dp" />

    <!-- D-Pad -->
    <Button
        android:id="@+id/btn_dpad_up"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="▲"
        android:backgroundTint="#37474F"
        app:layout_constraintBottom_toTopOf="@id/btn_dpad_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="120dp" />

    <Button
        android:id="@+id/btn_dpad_left"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="◀"
        android:backgroundTint="#37474F"
        app:layout_constraintBottom_toTopOf="@id/btn_dpad_down"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="168dp" />

    <Button
        android:id="@+id/btn_dpad_right"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="▶"
        android:backgroundTint="#37474F"
        app:layout_constraintBottom_toTopOf="@id/btn_dpad_down"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="72dp" />

    <Button
        android:id="@+id/btn_dpad_down"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="▼"
        android:backgroundTint="#37474F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="120dp"
        android:layout_marginBottom="20dp" />

    <!-- RIGHT SIDE -->

    <!-- RT -->
    <Button
        android:id="@+id/btn_rt"
        android:layout_width="80dp"
        android:layout_height="44dp"
        android:text="RT"
        android:textStyle="bold"
        android:backgroundTint="#546E7A"
        app:layout_constraintTop_toBottomOf="@id/btn_joy_disconnect"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp" />

    <!-- RB -->
    <Button
        android:id="@+id/btn_rb"
        android:layout_width="80dp"
        android:layout_height="36dp"
        android:text="RB"
        android:textStyle="bold"
        android:backgroundTint="#455A64"
        app:layout_constraintTop_toBottomOf="@id/btn_rt"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="4dp" />

    <!-- Right thumbstick -->
    <com.timothy.joystick.VirtualThumbstick
        android:id="@+id/right_stick"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp" />

    <!-- R3 -->
    <Button
        android:id="@+id/btn_r3"
        android:layout_width="48dp"
        android:layout_height="28dp"
        android:text="R3"
        android:textSize="10sp"
        android:backgroundTint="#263238"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="90dp"
        android:layout_marginBottom="4dp" />

    <!-- Face buttons -->
    <!-- Y -->
    <Button
        android:id="@+id/btn_y"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:text="Y"
        android:textStyle="bold"
        android:backgroundTint="#F9A825"
        app:layout_constraintBottom_toTopOf="@id/btn_x"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="80dp" />

    <!-- X (left) -->
    <Button
        android:id="@+id/btn_x"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:text="X"
        android:textStyle="bold"
        android:backgroundTint="#1565C0"
        app:layout_constraintBottom_toTopOf="@id/btn_a"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="28dp" />

    <!-- B -->
    <Button
        android:id="@+id/btn_b"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:text="B"
        android:textStyle="bold"
        android:backgroundTint="#B71C1C"
        app:layout_constraintBottom_toTopOf="@id/btn_a"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="132dp" />

    <!-- A -->
    <Button
        android:id="@+id/btn_a"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:text="A"
        android:textStyle="bold"
        android:backgroundTint="#1B5E20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="80dp"
        android:layout_marginBottom="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
